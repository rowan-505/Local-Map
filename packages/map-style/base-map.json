  "version": 8,
  "name": "Local Map Production Light",
  "metadata": {
    "local-map:purpose": "Rendering-only production basemap. Search, detail cards, and live CRUD data come from API/core.",
    "local-map:glyphs": "Self-hosted in apps/web/public/fonts/{fontstack}/ — MapLibre requests /fonts/{fontstack}/{range}.pbf from the web app origin. Use a single text-font so {fontstack} is one folder name (e.g. NotoSansMyanmar-Regular). Do not use multi-font stacks."
  },
