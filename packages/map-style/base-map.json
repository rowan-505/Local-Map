{
  "version": 8,
  "name": "Local Map Production Light",
  "metadata": {
    "local-map:purpose": "Rendering-only production basemap. Search, detail cards, and live CRUD data come from API/core.",
    "local-map:glyphs": "Self-hosted in apps/web/public/fonts/{fontstack}/ and apps/dashboard/public/fonts/{fontstack}/. MapLibre requests /fonts/{fontstack}/{range}.pbf. Use NotoSansMyanmar-Regular — the only self-hosted fontstack."
  },
  "glyphs": "/fonts/{fontstack}/{range}.pbf",
  "sources": {
    "local-basemap": {
      "type": "vector",
      "url": "pmtiles://https://pub-1f8b4bea1a884f51966c7916c5e618ce.r2.dev/basemaps/yangon/v1/basemap.pmtiles",
      "minzoom": 0,
      "maxzoom": 22
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f3f4f1"
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "local-basemap",
      "source-layer": "landuse",
      "minzoom": 8,
      "paint": {
        "fill-color": "#dce8d5",
        "fill-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8, 0.16,
          12, 0.26,
          16, 0.34
        ]
      }
    },
    {
      "id": "water-polygons",
      "type": "fill",
      "source": "local-basemap",
      "source-layer": "water_polygons",
      "paint": {
        "fill-color": "#b8ddea",
        "fill-opacity": 0.9
      }
    },
    {
      "id": "water-lines",
      "type": "line",
      "source": "local-basemap",
      "source-layer": "water_lines",
      "minzoom": 9,
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#9ccfe1",
        "line-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          9, 0.42,
          13, 0.68,
          17, 0.84
        ],
        "line-width": [
          "interpolate",
          ["exponential", 1.35],
          ["zoom"],
          9, 0.35,
          12, 0.8,
          15, 1.8,
          18, 4.2
        ]
      }
    },
    {
      "id": "admin-boundaries",
      "type": "line",
      "source": "local-basemap",
      "source-layer": "admin_boundaries",
      "minzoom": 8,
      "filter": [
        "any",
        ["!=", ["get", "admin_level_code"], "village"],
        [
          "all",
          ["==", ["get", "admin_level_code"], "village"],
          [
            "in",
            ["get", "boundary_status"],
            ["literal", ["official", "surveyed"]]
          ]
        ]
      ],
      "paint": {
        "line-color": "#8f9690",
        "line-dasharray": [2.5, 2.5],
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8, 0.45,
          12, 0.75,
          16, 1.1
        ],
        "line-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8,
          [
            "case",
            ["==", ["get", "admin_level_code"], "village"],
            0,
            0.22
          ],
          12,
          [
            "case",
            ["==", ["get", "admin_level_code"], "village"],
            0.28,
            0.34
          ],
          16,
          [
            "case",
            ["==", ["get", "admin_level_code"], "village"],
            0.38,
            0.42
          ]
        ]
      }
    },
    {
      "id": "admin-labels",
      "type": "symbol",
      "source": "local-basemap",
      "source-layer": "admin_areas",
      "minzoom": 8,
      "filter": ["!=", ["get", "admin_level_code"], "village"],
      "layout": {
        "text-field": [
          "coalesce",
          ["get", "name_mm"],
          ["get", "name_en"],
          ["get", "name"]
        ],
        "text-font": ["NotoSansMyanmar-Regular"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8, 9,
          12, 11,
          16, 13,
          20, 15
        ],
        "text-max-width": 8,
        "text-padding": 6,
        "text-allow-overlap": false,
        "text-ignore-placement": false,
        "text-optional": true
      },
      "paint": {
        "text-color": "#6f7670",
        "text-halo-color": "#f3f4f1",
        "text-halo-width": 1.4,
        "text-halo-blur": 0.2,
        "text-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8, 0.35,
          11, 0.55,
          14, 0.75
        ]
      }
    },
    {
      "id": "village-labels",
      "type": "symbol",
      "source": "local-basemap",
      "source-layer": "village_labels",
      "minzoom": 12,
      "layout": {
        "text-field": [
          "coalesce",
          ["get", "name_mm"],
          ["get", "name_en"],
          ["get", "name"]
        ],
        "text-font": ["NotoSansMyanmar-Regular"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12, 10,
          14, 11.5,
          17, 13,
          20, 14.5
        ],
        "text-max-width": 10,
        "text-padding": 8,
        "text-allow-overlap": false,
        "text-ignore-placement": false,
        "text-optional": true
      },
      "paint": {
        "text-color": "#5c635d",
        "text-halo-color": "#f3f4f1",
        "text-halo-width": 1.5,
        "text-halo-blur": 0.25,
        "text-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12, 0.45,
          13, 0.62,
          14, 0.78,
          16, 0.88
        ]
      }
    },
    {
      "id": "road-casing",
      "type": "line",
      "source": "local-basemap",
      "source-layer": "streets",
      "minzoom": 10,
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#ffffff",
        "line-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          10, 0.62,
          13, 0.82,
          17, 0.94
        ],
        "line-width": [
          "interpolate",
          ["exponential", 1.45],
          ["zoom"],
          10, 1.488,
          12, 2.232,
          14, 4.216,
          16, 7.936,
          19, 16.74
        ]
      }
    },
    {
      "id": "road-fill",
      "type": "line",
      "source": "local-basemap",
      "source-layer": "streets",
      "minzoom": 10,
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#c1c4bf",
        "line-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          10, 0.52,
          13, 0.78,
          17, 0.92
        ],
        "line-width": [
          "interpolate",
          ["exponential", 1.45],
          ["zoom"],
          10, 0.737,
          12, 1.273,
          14, 2.546,
          16, 5.36,
          19, 12.596
        ]
      }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "local-basemap",
      "source-layer": "buildings",
      "minzoom": 14,
      "paint": {
        "fill-color": "#ded8cf",
        "fill-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          14, 0.48,
          17, 0.72,
          22, 0.72
        ],
        "fill-outline-color": "#c7beb2"
      }
    },
    {
      "id": "road-labels",
      "type": "symbol",
      "source": "local-basemap",
      "source-layer": "road_labels",
      "minzoom": 13,
      "layout": {
        "symbol-placement": "line",
        "symbol-spacing": 350,
        "text-field": [
          "coalesce",
          ["get", "name_mm"],
          ["get", "name_en"],
          ["get", "name"]
        ],
        "text-font": ["NotoSansMyanmar-Regular"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          13, 10,
          16, 11.5,
          19, 14
        ],
        "text-padding": 4,
        "text-max-angle": 30,
        "text-rotation-alignment": "map",
        "text-keep-upright": true
      },
      "paint": {
        "text-color": "#4f575c",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.45,
        "text-halo-blur": 0.25
      }
    }
  ]
}
