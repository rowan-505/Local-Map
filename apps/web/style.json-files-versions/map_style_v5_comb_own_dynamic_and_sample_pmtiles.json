{
  "version": 8,
  "name": "Base light + Martin local Kyauktan overlay",
  "metadata": {
    "mapweb:file_role": "Primary MapLibre style JSON (static spec; not runtime-generated).",
    "mapweb:layer_stack_note": "layers[] order is paint order: first entry = bottom, last = top (before app moveLayer for GeoJSON POIs).",
    "mapweb:basemap_layer_ids": [
      "background",
      "water-fill",
      "water-way",
      "roads-major",
      "roads-minor",
      "buildings",
      "places"
    ],
    "mapweb:dynamic_layer_ids": [
      "dynamic-route-line",
      "dynamic-poi-circle",
      "dynamic-poi-label"
    ],
    "mapweb:tile_schema": "Protomaps basemap v4 (vector_layers from PMTiles metadata + docs.protomaps.com/basemaps/layers)",
    "mapweb:source_layer_ids": "water, roads, buildings, places (and boundaries, earth, landcover, landuse, pois in archive)",
    "mapweb:label_fields": "name, name:* (e.g. name:en); places use kind + kind_detail (not OpenMapTiles class)",
    "mapweb:basemap_url": "Wired to Protomaps basemap v4 at pmtiles://https://demo-bucket.protomaps.com/v4.pmtiles (vector_layers verified: water, roads, buildings, places, …). Replace url only if you point at a different archive.",
    "mapweb:glyphs": "OpenFreeMap fonts; text-font Noto Sans Regular matches {fontstack}.",
    "mapweb:water": "Protomaps v4: single vector layer id \"water\" (polygons + lines). One fill: Polygon, exclude kind playa/other. One line: LineString + kind_detail river|stream|canal|ditch|drain. No separate waterway source-layer in this schema.",
    "mapweb:dynamic_source": "Martin local PostGIS vector tile views: v_admin_areas, v_streets, v_places",
    "mapweb:dynamic_overlay_layers": "martin-admin-fill, martin-admin-line, martin-streets-line, martin-street-label, martin-places-circle, martin-places-label",
    "mapweb:dynamic_planned_layer_ids": "Further slots (no layers yet): dynamic-verified-places, dynamic-update-patches.",
    "maputnik:renderer": "mlgljs"
  },
  "center": [
    96.324,
    16.64
  ],
  "zoom": 13,
  "sources": {
    "basemap": {
      "type": "vector",
      "url": "pmtiles://https://demo-bucket.protomaps.com/v4.pmtiles",
      "minzoom": 0,
      "maxzoom": 15,
      "attribution": "<a href=\"https://protomaps.com\">Protomaps</a> © <a href=\"https://openstreetmap.org\">OpenStreetMap</a>"
    },
    "martin_admin_areas": {
      "type": "vector",
      "tiles": [
        "https://martin-lively-canyon-4077.fly.dev/v_admin_areas/{z}/{x}/{y}"
      ],
      "minzoom": 0,
      "maxzoom": 22,
      "attribution": "Local Kyauktan admin areas via Martin/PostGIS"
    },
    "martin_streets": {
      "type": "vector",
      "tiles": [
        "https://martin-lively-canyon-4077.fly.dev/v_streets/{z}/{x}/{y}"
      ],
      "minzoom": 0,
      "maxzoom": 22,
      "attribution": "Local Kyauktan streets via Martin/PostGIS"
    },
    "martin_places": {
      "type": "vector",
      "tiles": [
        "https://martin-lively-canyon-4077.fly.dev/v_places/{z}/{x}/{y}"
      ],
      "minzoom": 0,
      "maxzoom": 22,
      "attribution": "Local Kyauktan places via Martin/PostGIS"
    }
  },
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f6f5f2"
      }
    },
    {
      "id": "water-fill",
      "type": "fill",
      "source": "basemap",
      "source-layer": "water",
      "filter": [
        "all",
        [
          "==",
          [
            "geometry-type"
          ],
          "Polygon"
        ],
        [
          "!",
          [
            "in",
            [
              "get",
              "kind"
            ],
            [
              "literal",
              [
                "playa",
                "other"
              ]
            ]
          ]
        ]
      ],
      "paint": {
        "fill-opacity": 0.9,
        "fill-color": "rgba(110, 197, 230, 1)"
      }
    },
    {
      "id": "water-way",
      "type": "line",
      "source": "basemap",
      "source-layer": "waterway",
      "minzoom": 8,
      "maxzoom": 24,
      "filter": [
        "all",
        [
          "==",
          [
            "geometry-type"
          ],
          "LineString"
        ],
        [
          "in",
          [
            "get",
            "kind_detail"
          ],
          [
            "literal",
            [
              "river",
              "stream",
              "canal",
              "ditch",
              "drain"
            ]
          ]
        ]
      ],
      "layout": {
        "visibility": "visible"
      },
      "paint": {
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          8,
          0.5,
          11,
          0.8,
          14,
          1.2,
          17,
          1.6
        ],
        "line-opacity": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          8,
          0.55,
          11,
          0.72,
          14,
          0.82
