NODE_ENV=
PORT=
# Supabase pooler should use a small connection_limit to avoid exhausting max clients.
# Use transaction pooler port 6543 for local app traffic if session pooler is saturated.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/DATABASE?pgbouncer=true&connection_limit=3
JWT_SECRET=
CORS_ORIGIN=http://localhost:5173,https://map-web-seven.vercel.app,https://db-dashboard-ebon.vercel.app
AUTH_BYPASS=true