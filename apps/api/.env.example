NODE_ENV=
PORT=
JWT_SECRET=
# Supabase: use a low connection_limit so the API + Fly Martin + dashboards do not exhaust the pool.
# Transaction pooler (port 6543) + pgbouncer=true is recommended for serverless / many small clients.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/DATABASE?pgbouncer=true&connection_limit=1
# If DATABASE_URL omits connection_limit, Prisma appends one (default 1 unless set here).
PRISMA_CONNECTION_LIMIT=

CORS_ORIGIN=http://localhost:5173,https://map-web-seven.vercel.app,https://db-dashboard-ebon.vercel.app
AUTH_BYPASS=true
