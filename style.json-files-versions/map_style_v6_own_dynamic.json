{
  "version": 8,
  "name": "Dynamic Tiles Debug",

  "center": [96.324, 16.64],
  "zoom": 14,

  "sources": {
    "admin": {
      "type": "vector",
      "tiles": ["http://localhost:3000/v_admin_areas/{z}/{x}/{y}"]
    },
    "streets": {
      "type": "vector",
      "tiles": ["http://localhost:3000/v_streets/{z}/{x}/{y}"]
    },
    "places": {
      "type": "vector",
      "tiles": ["http://localhost:3000/v_places/{z}/{x}/{y}"]
    }
  },

"layers": [
    {

 
      "id": "admin-fill",
      "type": "fill",
      "source": "admin",
      "source-layer": "v_admin_areas",
      "paint": {
        "fill-color": "#60a5fa",
        "fill-opacity": 0.2
      }
    },
    {
      "id": "admin-border",
      "type": "line",
      "source": "admin",
      "source-layer": "v_admin_areas",
      "paint": {
        "line-color": "#2563eb",
        "line-width": 2
      }
    },
    {
      "id": "admin-label",
      "type": "symbol",
      "source": "admin",
      "source-layer": "v_admin_areas",
      "minzoom": 10,
      "layout": {
        "text-field": ["coalesce", ["get", "name"], ""],
        "text-font": ["Noto Sans Regular"],
        "text-size": 14,
        "text-anchor": "center"
      },
      "paint": {
        "text-color": "#1d4ed8",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    },


    {
      "id": "streets-line",
      "type": "line",
      "source": "streets",
      "source-layer": "v_streets",
      "paint": {
        "line-color": "#111827",
        "line-width": 2
      }
    },
    {
      "id": "streets-label",
      "type": "symbol",
      "source": "streets",
      "source-layer": "v_streets",
      "minzoom": 14,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name"], ""],
        "text-font": ["Noto Sans Regular"],
        "text-size": 11,
        "text-allow-overlap": false
      },
      "paint": {
        "text-color": "#374151",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.2
      }
    },

 {
      "id": "places-circle",
      "type": "circle",
      "source": "places",
      "source-layer": "v_places",
      "paint": {
        "circle-radius": 6,
        "circle-color": "#ef4444",
        "circle-stroke-color": "#ffffff",
        "circle-stroke-width": 1.5
      }
    },
    {
      "id": "places-label",
      "type": "symbol",
      "source": "places",
      "source-layer": "v_places",
      "minzoom": 13,
      "layout": {
        "text-field": ["coalesce", ["get", "name"], ""],
        "text-font": ["Noto Sans Regular"],
        "text-size": 12,
        "text-offset": [0, 1],
        "text-anchor": "top",
        "text-allow-overlap": false
      },
      "paint": {
        "text-color": "#111827",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    }

  ]
}