{
  "version": 8,
  "name": "Township MVP — minimal light",
  "metadata": { "maputnik:renderer": "mlgljs" },
  "sources": {
    "carto-light": {
      "type": "raster",
      "tiles": [
        "https://a.basemaps.cartocdn.com/light_all/{z}/{x}/{y}.png",
        "https://b.basemaps.cartocdn.com/light_all/{z}/{x}/{y}.png",
        "https://c.basemaps.cartocdn.com/light_all/{z}/{x}/{y}.png"
      ],
      "tileSize": 256,
      "attribution": "© <a href=\"https://www.openstreetmap.org/copyright\" rel=\"noreferrer\">OpenStreetMap</a> © <a href=\"https://carto.com/attributions\" rel=\"noreferrer\">CARTO</a>",
      "maxzoom": 22
    }
  },
  "layers": [
    {
      "id": "carto-light",
      "type": "raster",
      "source": "carto-light",
      "minzoom": 0,
      "maxzoom": 22,
      "paint": {
        "raster-opacity": 1,
        "raster-fade-duration": 0
      }
    }
  ]
}
