#!/usr/bin/env bash
# =============================================================================
# Local OSM import — full env template (safe to commit; no secrets)
# =============================================================================
#
# Copy for each import:
#   cp imports/template.full.env imports/kyauktan_2026_07_v4.env
#
# Edit the copy, then run:
#   ./run_local_osm_pipeline.sh imports/kyauktan_2026_07_v4.env
#
# Naming: see NAMINGENV.md in the parent folder.
# =============================================================================

# --- Local database (import lab only — not Supabase) ---
export LOCAL_DATABASE_URL='postgresql://postgres:YOUR_PASSWORD@localhost:5433/geo_core'

# --- Source registry (must exist in system.system_source_registry) ---
export SOURCE_CODE='osm_myanmar'
export REGION_CODE='MM-KYAUKTAN'

# --- Input extract ---
export PBF_PATH='/absolute/path/to/myanmar-latest.osm.pbf'
export SNAPSHOT_REF='myanmar-latest.osm.pbf'

# --- Import boundary (GeoJSON, registered before snapshot creation) ---
export BOUNDARY_GEOJSON_PATH='/absolute/path/to/kyauktan-boundary.geojson'
export BOUNDARY_CODE='kyauktan_boundary'
export BOUNDARY_NAME='Kyauktan Township Boundary'
export BOUNDARY_VERSION='v4'

# --- Import identity (unique per run; see NAMINGENV.md) ---
export SNAPSHOT_VERSION='osm_myanmar_2026_07_kyauktan_v4'
export BATCH_NAME='kyauktan_osm_import_2026_07_v4'

# --- Integrity ---
# PBF and boundary checksums are calculated by the runner/scripts with shasum -a 256.

# --- osm2pgsql flex config for tmp_import stage ---
export OSM2PGSQL_FLEX_FILE='/absolute/path/to/Local-Map/tools/data-pipeline/local-osm/lua/osm2pgsql_tmp_import.lua'

# --- Pipeline logs (directory must exist or will be created by runner) ---
export LOG_DIR='/absolute/path/to/Local-Map/logs/data-pipeline'

# --- Optional outbound review packages (Stages 11–13; never promotes to core) ---
# Exactly one runner mode applies:
#   - REMOTE_REVIEW_UPLOAD_ENABLED=true/1/yes → Stage J (.sql), K (.ts), L (.sql) in order (needs Supabase URL).
#   - REMOTE_REVIEW_PREPARE_VERIFY_ONLY=true/1/yes → Stage J + L only (local DB only).
#
# Required for either mode once enabled:
# export REMOTE_REVIEW_PACKAGE_NAME='remote_review_pkg_osm_myanmar_2026_07_kyauktan_v4'
#
# export REMOTE_REVIEW_UPLOAD_ENABLED='false'
# export REMOTE_REVIEW_PREPARE_VERIFY_ONLY='false'
# export SUPABASE_DATABASE_URL='postgresql://postgres:YOUR_PASSWORD@...:5432/postgres'
#
# Optional filters applied to BOTH Stage J and Stage K when set:
# export REMOTE_REVIEW_ENTITY_FAMILY=''   # buildings | places | roads (empty = all)
# export REMOTE_REVIEW_MAX_ROWS_PER_FAMILY=''  # integer cap per entity family slice
#
# Optional strict TLS verification for Stage K vs Supabase (omit unless you need CA chain verify):
# export SUPABASE_DB_SSL_VERIFY_SERVER_CERT='true'
#
# Optional lineage QA (local-only `14_verify_lineage_alignment.sql`, after Stage L — same gate as J/L):
# export REMOTE_LINEAGE_ALIGNMENT_VERIFY='true'

# --- Optional schema overrides (defaults shown) ---
# export TMP_IMPORT_SCHEMA='tmp_import'
# export RAW_SCHEMA='raw'
# export STAGING_SCHEMA='staging'
# export SYSTEM_SCHEMA='system'
# export OSM2PGSQL='osm2pgsql'
# export PSQL_EXTRA_ARGS=''
# export ALLOW_BOUNDARY_UPDATE='false'
