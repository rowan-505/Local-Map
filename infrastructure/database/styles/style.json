{
  "version": 8,
  "name": "Local Dynamic Basemap",
  "metadata": {
    "context": "docs/database_pipeline_context.md",
    "renderer": "maplibre",
    "tile_server": "martin",
    "local_development_only": true
  },
  "sources": {
    "dynamic_basemap": {
      "type": "vector",
      "url": "http://localhost:3000/tiles_admin_boundaries_v,tiles_buildings_v,tiles_landuse_v,tiles_places_v,tiles_roads_v,tiles_road_labels_v,tiles_water_lines_v,tiles_water_polygons_v,tiles_streets_v,tiles_admin_areas_v,tiles_places_legacy_v,tiles_poi_v,tiles_bus_routes_v,tiles_bus_stops_v"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f7f8fa"
      }
    },
    {
      "id": "landuse-fill",
      "type": "fill",
      "source": "dynamic_basemap",
      "source-layer": "tiles_landuse_v",
      "minzoom": 5,
      "paint": {
        "fill-color": [
          "match",
          ["get", "landuse_class"],
          "forest",
          "#dbead5",
          "wood",
          "#dbead5",
          "grassland",
          "#e7f0dc",
          "scrub",
          "#e3ecd7",
          "wetland",
          "#d8ece8",
          "park",
          "#e3f1dc",
          "recreation_ground",
          "#e5f1df",
          "#eef2e7"
        ],
        "fill-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5,
          0.35,
          10,
          0.5,
          14,
          0.6
        ]
      }
    },
    {
      "id": "water-polygons-fill",
      "type": "fill",
      "source": "dynamic_basemap",
      "source-layer": "tiles_water_polygons_v",
      "paint": {
        "fill-color": "#cfe7f6",
        "fill-opacity": 0.9
      }
    },
    {
      "id": "buildings-fill",
      "type": "fill",
      "source": "dynamic_basemap",
      "source-layer": "tiles_buildings_v",
      "minzoom": 13,
      "paint": {
        "fill-color": "#e6e1db",
        "fill-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          13,
          0.35,
          15,
          0.55,
          17,
          0.7
        ],
        "fill-outline-color": "#d7d1ca"
      }
    },
    {
      "id": "water-lines",
      "type": "line",
      "source": "dynamic_basemap",
      "source-layer": "tiles_water_lines_v",
      "minzoom": 9,
      "paint": {
        "line-color": "#9fcbea",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          9,
          0.6,
          12,
          1.1,
          15,
          2.2
        ],
        "line-opacity": 0.9
      }
    },
    {
      "id": "road-casing",
      "type": "line",
      "source": "dynamic_basemap",
      "source-layer": "tiles_roads_v",
      "minzoom": 8,
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#d5d9df",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8,
          0.8,
          10,
          1.4,
          12,
          2.4,
          14,
          4.4,
          16,
          8.5
        ],
        "line-opacity": 0.95
      }
    },
    {
      "id": "road-main",
      "type": "line",
      "source": "dynamic_basemap",
      "source-layer": "tiles_roads_v",
      "minzoom": 8,
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#ffffff",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8,
          0.3,
          10,
          0.8,
          12,
          1.6,
          14,
          3.0,
          16,
          6.2
        ],
        "line-opacity": 1
      }
    },
    {
      "id": "admin-boundaries",
      "type": "line",
      "source": "dynamic_basemap",
      "source-layer": "tiles_admin_boundaries_v",
      "minzoom": 7,
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#b48fb8",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          7,
          0.5,
          10,
          0.8,
          13,
          1.2
        ],
        "line-dasharray": [2, 2],
        "line-opacity": 0.7
      }
    },
    {
      "id": "road-labels",
      "type": "symbol",
      "source": "dynamic_basemap",
      "source-layer": "tiles_road_labels_v",
      "minzoom": 13,
      "filter": [
        "all",
        ["has", "name"],
        ["!=", ["get", "name"], ""]
      ],
      "layout": {
        "symbol-placement": "line",
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular", "Arial Unicode MS Regular", "sans-serif"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          13,
          10,
          16,
          13
        ],
        "text-letter-spacing": 0.02,
        "text-max-angle": 45,
        "text-padding": 2
      },
      "paint": {
        "text-color": "#6c7480",
        "text-halo-color": "#f7f8fa",
        "text-halo-width": 1.2,
        "text-halo-blur": 0.4
      }
    },
    {
      "id": "place-labels",
      "type": "symbol",
      "source": "dynamic_basemap",
      "source-layer": "tiles_places_v",
      "minzoom": 11,
      "filter": [
        "all",
        ["has", "name"],
        ["!=", ["get", "name"], ""]
      ],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular", "Arial Unicode MS Regular", "sans-serif"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          11,
          11,
          14,
          13,
          17,
          16
        ],
        "text-offset": [0, 0.6],
        "text-anchor": "top",
        "text-max-width": 10,
        "symbol-sort-key": [
          "coalesce",
          ["get", "importance_score"],
          0
        ]
      },
      "paint": {
        "text-color": "#4c5563",
        "text-halo-color": "#f7f8fa",
        "text-halo-width": 1.3,
        "text-halo-blur": 0.5
      }
    }
  ]
}
