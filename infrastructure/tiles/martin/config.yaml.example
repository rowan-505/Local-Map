# Copy to config.yaml (optional — committed config.yaml is already safe) or use as reference.
# Set DATABASE_URL in the environment before starting Martin or deploying to Fly.
#
#   export DATABASE_URL='postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require'
#   martin --config config.yaml

listen_addresses: "0.0.0.0:3000"

postgres:
  connection_string: ${DATABASE_URL:?Set DATABASE_URL}

  auto_publish:
    from_schemas:
      - tiles

  tables:
    tiles_buildings_v:
      schema: tiles
      table: tiles_buildings_v
      srid: 4326
      geometry_column: geom
      id_column: id
